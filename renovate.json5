{
  "ansible": {
    "fileMatch": ["ansible/.+\\.ya?ml$"]
  },
  "kubernetes": {
    "fileMatch": ["k8s/.+\\.yaml$"]
  },
  "helm-values": {
    "fileMatch": ["k8s/.+values.*\\.ya?ml$"]
  },
  "argocd": {
    "fileMatch": ["k8s/argocd/applications/.+\\.ya?ml$"]
  },


  "packageRules": [
    {
      "matchPackagePatterns": [
        ".*\\/qbittorrent",
        ".*\\/calibre-web",
        ".*\\/overseerr",
        "kube-prometheus-stack",
        "traefik",
        "kubernetes"
      ],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    },
  ],
}
