{
  "ansible": {
    "fileMatch": ["ansible/.+\\.ya?ml$"]
  },
  "kubernetes": {
    "fileMatch": ["k8s/.+\\.yaml$"]
  },
  "helm-values": {
    "fileMatch": ["k8s/.+values.*\\.ya?ml$"]
  },
  "argocd": {
    "fileMatch": ["k8s/argocd/applications/.+\\.ya?ml$"]
  },


  "packageRules": [
    {
      "matchPackageNames": ["lscr.io/linuxserver/qbittorrent"],
      "versioning": "regex:^(?<major>\\d)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    },

    {
      "matchPackageNames": ["lscr.io/linuxserver/calibre-web"],
      "versioning": "regex:^(?<major>\\d)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    },

    {
      "matchPackageNames": ["lscr.io/linuxserver/overseerr"],
      "versioning": "regex:^(?<major>\\d)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    }
  ],
}
