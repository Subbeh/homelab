---

http:
  routers:
    sabnzbd-rtr-bypass:
      rule: "Host(`sabnzbd.{{ network_domain.tld }}`) && Query(`apikey={{ media_sabnzbd_api }}`)"
      priority: 100
      entryPoints:
        - websecure
      middlewares:
        - chain-no-auth
      service: sabnzbd-svc
    sabnzbd-rtr:
      rule: "Host(`sabnzbd.{{ network_domain.tld }}`)"
      priority: 99
      entryPoints:
        - websecure
      middlewares:
        - chain-auth
      service: sabnzbd-svc
  services:
    sabnzbd-svc:
      loadBalancer:
        servers:
          - url: "http://{{ network_svc.sabnzbd.host }}:{{ network_svc.sabnzbd.port }}"
