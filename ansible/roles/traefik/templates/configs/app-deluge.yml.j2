---

http:
  routers:
    deluge-rtr-bypass:
      rule: "Host(`deluge.{{ network_domain.tld }}`) && Headers(`Content-Type`, `application/json`)"
      priority: 100
      entryPoints:
        - websecure
      middlewares:
        - chain-no-auth
      service: deluge-svc
    deluge-rtr:
      rule: "Host(`deluge.{{ network_domain.tld }}`)"
      priority: 99
      entryPoints:
        - websecure
      middlewares:
        - chain-auth
      service: deluge-svc
  services:
    deluge-svc:
      loadBalancer:
        servers:
          - url: "http://{{ network_svc.deluge.host }}:{{ network_svc.deluge.port }}"
